<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Leave Requests — EMS</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

<nav class="navbar">
  <a href="<%= userRole === 'dean' ? '/dashboard/dean' : '/dashboard/user' %>" class="nav-brand">
    <div class="brand-icon">E</div><span class="brand-name">EMS</span>
  </a>
  <div class="nav-links">
    <% if (userRole === 'dean') { %>
      <a href="/dashboard/dean" class="nav-link" id="nav-dash">🏠 Dashboard</a>
      <a href="/employees"      class="nav-link" id="nav-emp">👥 Employees</a>
      <a href="/departments"    class="nav-link" id="nav-dept">🏢 Departments</a>
      <a href="/attendance"     class="nav-link" id="nav-att">📅 Attendance</a>
    <% } else { %>
      <a href="/dashboard/user"  class="nav-link" id="nav-dash">🏠 Dashboard</a>
      <a href="/attendance/my"   class="nav-link" id="nav-myatt">📅 My Attendance</a>
      <a href="/change-password" class="nav-link" id="nav-pwd">🔑 Password</a>
    <% } %>
    <a href="/leaves" class="nav-link active" id="nav-leaves">🌴 Leaves</a>
  </div>
  <div style="display:flex;align-items:center;gap:10px;margin-left:auto;">
    <button id="themeToggle" class="theme-toggle-btn">🌙</button>
    <button id="hamburger" class="hamburger-btn"><span></span><span></span><span></span></button>
    <form action="/logout" method="POST">
      <button type="submit" class="btn btn-secondary btn-sm" id="logout-btn">Logout</button>
    </form>
  </div>
</nav>

<div id="mobileNav" class="mobile-nav">
  <a href="<%= userRole === 'dean' ? '/dashboard/dean' : '/dashboard/user' %>">🏠 Dashboard</a>
  <a href="/leaves">🌴 Leave Requests</a>
  <a href="/attendance<%= userRole === 'faculty' ? '/my' : '' %>">📅 Attendance</a>
  <a href="/change-password">🔑 Change Password</a>
  <div class="mobile-divider"></div>
  <form action="/logout" method="POST">
    <button type="submit" class="btn btn-secondary btn-sm" style="width:100%">Logout</button>
  </form>
</div>

<div class="main-content">
  <div class="page-wrapper">

    <div class="page-header animate-in" style="margin-bottom:28px;">
      <div>
        <h1 style="font-size:1.7rem;">🌴 Leave Requests</h1>
        <p style="color:var(--text-muted);margin-top:4px;">
          <% if (userRole === 'dean') { %>All leave requests across the institution<% } else if (userRole === 'hod') { %>Leave requests in your department<% } else { %>Your submitted leave requests<% } %>
        </p>
      </div>
      <button class="btn btn-primary" onclick="document.getElementById('leaveFormPanel').classList.toggle('hidden')" id="newLeaveBtn">+ New Request</button>
    </div>

    <!-- Flash Messages -->
    <% if (query && query.error) { %>
      <div class="alert alert-error animate-in" data-auto-dismiss><span>⚠</span> <%= query.error.replace(/\+/g,' ') %></div>
    <% } %>
    <% if (query && query.success) { %>
      <div class="alert alert-success animate-in" data-auto-dismiss><span>✓</span> <%= query.success.replace(/\+/g,' ') %></div>
    <% } %>

    <!-- New Leave Request Form -->
    <div id="leaveFormPanel" class="card animate-in hidden" style="margin-bottom:24px;">
      <div class="card-header"><h3 class="card-title">📝 Submit Leave Request</h3></div>
      <form action="/leaves/request" method="POST" id="leaveRequestForm">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;">
          <div class="form-group">
            <label for="leaveType">Leave Type</label>
            <select name="type" id="leaveType" required>
              <option value="Sick">🤒 Sick Leave</option>
              <option value="Casual">🏖 Casual Leave</option>
              <option value="Annual">📅 Annual Leave</option>
              <option value="Other">📌 Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="leaveStart">Start Date</label>
            <input type="date" name="startDate" id="leaveStart" required>
          </div>
          <div class="form-group">
            <label for="leaveEnd">End Date</label>
            <input type="date" name="endDate" id="leaveEnd" required>
          </div>
        </div>
        <div class="form-group">
          <label for="leaveReason">Reason <span style="color:var(--text-muted);font-weight:400;">(optional)</span></label>
          <textarea name="reason" id="leaveReason" rows="2" placeholder="Brief reason for leave..." style="resize:vertical;"></textarea>
        </div>
        <div style="display:flex;gap:12px;">
          <button type="submit" class="btn btn-primary" id="submitLeaveBtn">Submit Request</button>
          <button type="button" class="btn btn-secondary" onclick="document.getElementById('leaveFormPanel').classList.add('hidden')" id="cancelLeaveBtn">Cancel</button>
        </div>
      </form>
    </div>

    <!-- Leaves List -->
    <div class="card animate-in delay-1">
      <div class="card-header">
        <h3 class="card-title">📋 All Requests</h3>
        <span class="badge badge-purple"><%= leaves.length %> request<%= leaves.length !== 1 ? 's' : '' %></span>
      </div>

      <% if (leaves.length === 0) { %>
        <div class="empty-state"><div class="empty-icon">🌴</div><p>No leave requests found.</p></div>
      <% } else { %>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <% leaves.forEach(leave => { %>
            <div class="leave-card animate-in">
              <div style="width:42px;height:42px;background:var(--bg-secondary);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">
                <%= leave.type === 'Sick' ? '🤒' : leave.type === 'Casual' ? '🏖' : leave.type === 'Annual' ? '📅' : '📌' %>
              </div>
              <div class="leave-meta">
                <% if (userRole !== 'faculty') { %>
                  <div style="font-weight:600;font-size:0.9rem;"><%= leave.employeeId ? leave.employeeId.name : 'Unknown' %> <span style="color:var(--text-muted);font-weight:400;">· <%= leave.employeeId ? leave.employeeId.employeeId : '' %></span></div>
                <% } %>
                <div style="font-weight:600;font-size:0.9rem;color:var(--text-primary);"><%= leave.type %> Leave</div>
                <div style="font-size:0.8rem;color:var(--text-muted);">
                  <%= new Date(leave.startDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %> → <%= new Date(leave.endDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
                </div>
                <% if (leave.reason) { %>
                  <div style="font-size:0.8rem;color:var(--text-secondary);margin-top:2px;"><i>"<%= leave.reason %>"</i></div>
                <% } %>
                <% if (leave.reviewComment && leave.status !== 'Pending') { %>
                  <div style="font-size:0.78rem;color:var(--text-muted);margin-top:2px;">Comment: <%= leave.reviewComment %></div>
                <% } %>
              </div>
              <div class="leave-actions">
                <% if (leave.status === 'Pending') { %><span class="badge badge-pending">⏳ Pending</span>
                <% } else if (leave.status === 'Approved') { %><span class="badge badge-approved">✓ Approved</span>
                <% } else { %><span class="badge badge-rejected">✗ Rejected</span><% } %>

                <!-- HOD/Dean can review pending leaves -->
                <% if ((userRole === 'dean' || userRole === 'hod') && leave.status === 'Pending') { %>
                  <form action="/leaves/review/<%= leave._id %>" method="POST" style="display:inline;">
                    <select name="status" style="padding:4px 8px;font-size:0.78rem;border-radius:6px;border:1px solid var(--border);" id="reviewStatus_<%= leave._id %>">
                      <option value="Approved">Approve</option>
                      <option value="Rejected">Reject</option>
                    </select>
                    <input type="text" name="reviewComment" placeholder="Comment..." style="padding:4px 8px;font-size:0.78rem;border-radius:6px;border:1px solid var(--border);max-width:130px;" id="reviewComment_<%= leave._id %>">
                    <button type="submit" class="btn btn-primary btn-sm" id="reviewBtn_<%= leave._id %>">Submit</button>
                  </form>
                <% } %>

                <!-- Can delete own pending leave -->
                <% if (leave.status === 'Pending') { %>
                  <form action="/leaves/delete/<%= leave._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Delete this leave request?')">
                    <button type="submit" class="btn btn-danger btn-sm" id="delLeave_<%= leave._id %>">✕</button>
                  </form>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<style>
.hidden { display: none !important; }
textarea { width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:var(--radius-sm);font-family:inherit;font-size:0.9rem;background:var(--bg-input);color:var(--text-primary); }
textarea:focus { outline:none;border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow); }
</style>
<script src="/app.js"></script>
</body>
</html>
