<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Member — <%= dept.name %> — EMS</title>
  <link rel="stylesheet" href="/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
</head>

<body>

  <nav class="navbar">
    <a href="/departments" class="nav-brand">
      <div class="brand-icon">E</div>
      <span class="brand-name">EMS</span>
    </a>
    <div class="nav-links">
      <a href="<%= userRole === 'dean' ? '/dashboard/dean' : '/dashboard/user' %>" class="nav-link" id="nav-dash">🏠
        Dashboard</a>
      <% if (userRole==='dean' ) { %>
        <a href="/employees" class="nav-link" id="nav-emp">👥 Employees</a>
        <% } %>
          <a href="/departments" class="nav-link active" id="nav-dept">🏢 Departments</a>
          <a href="/attendance" class="nav-link" id="nav-att">📅 Attendance</a>
          <a href="/leaves" class="nav-link" id="nav-leaves">🌴 Leaves</a>
    </div>
    <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
      <button id="themeToggle" class="theme-toggle-btn" title="Toggle dark mode">🌙</button>
      <button id="hamburger" class="hamburger-btn" aria-expanded="false"><span></span><span></span><span></span></button>
      <form action="/logout" method="POST">
        <button type="submit" class="btn btn-secondary btn-sm" id="logout-btn">Logout</button>
      </form>
    </div>
  </nav>

  <div id="mobileNav" class="mobile-nav">
    <a href="<%= userRole === 'dean' ? '/dashboard/dean' : '/dashboard/user' %>">🏠 Dashboard</a>
    <% if (userRole==='dean' ) { %><a href="/employees">👥 Employees</a>
      <% } %>
        <a href="/departments">🏢 Departments</a>
        <a href="/attendance">📅 Attendance</a>
        <a href="/leaves">🌴 Leaves</a>
        <div class="mobile-divider"></div>
        <form action="/logout" method="POST">
          <button type="submit" class="btn btn-secondary btn-sm" style="width:100%;">Logout</button>
        </form>
  </div>

  <div class="main-content">
    <div class="page-wrapper" style="max-width:950px;">

      <!-- Breadcrumb + Header -->
      <div class="animate-in" style="margin-bottom:28px;">
        <p style="font-size:0.8rem;color:var(--text-muted);margin-bottom:8px;">
          <a href="/departments" style="color:var(--accent);text-decoration:none;">🏢 Departments</a>
          <span style="margin:0 6px;">›</span>
          <span>
            <%= dept.name %>
          </span>
          <span style="margin:0 6px;">›</span>
          <span>Add Member</span>
        </p>
        <div>
          <h1 style="font-size:1.8rem;font-weight:800;">Add New Member</h1>
          <p style="color:var(--text-muted);margin-top:4px;">Fill out the form below to add a new employee to the <%=
              dept.name %> department.</p>
        </div>
      </div>

      <!-- The Form -->
      <div class="card animate-in delay-1" style="padding:32px;">
        <form action="/employees/add" method="POST" id="addMemberForm">
          <input type="hidden" name="department" value="<%= dept.name %>">

          <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));gap:20px;margin-bottom:20px;">
            <div class="form-group" style="margin:0;">
              <label>Department</label>
              <input type="text" value="<%= dept.name %>" disabled style="background:var(--bg-secondary);opacity:0.8;">
            </div>
            <div class="form-group" style="margin:0;">
              <label for="roleSelect">Designation</label>
              <select name="role" id="roleSelect" onchange="onRoleChange()" required>
                <option value="faculty">Faculty</option>
                <% if (userRole==='dean' ) { %>
                  <option value="hod">Head of Department</option>
                  <% } %>
              </select>
            </div>
            <div class="form-group" style="margin:0;">
              <label for="previewMemberId">Employee ID (Auto-Generated)</label>
              <input type="text" name="employeeId" id="previewMemberId" readonly placeholder="Generating…"
                style="font-family:monospace;color:var(--accent);background:var(--bg-secondary);" required>
            </div>
          </div>

          <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));gap:20px;margin-bottom:20px;">
            <div class="form-group" style="margin:0;">
              <label for="memberName">Full Name</label>
              <input type="text" name="name" id="memberName" placeholder="e.g. Dr. Jane Smith" required>
            </div>
            <div class="form-group" style="margin:0;">
              <label for="memberEmail">Email Address</label>
              <input type="email" name="email" id="memberEmail" placeholder="jane.smith@institution.edu" required>
            </div>
            <div class="form-group" style="margin:0;">
              <label for="memberPhone">Phone Number</label>
              <input type="text" name="phone" id="memberPhone" placeholder="+91 98765 43210">
            </div>
          </div>

          <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));gap:20px;margin-bottom:20px;">
            <div class="form-group" style="margin:0;">
              <label for="memberPosition">Internal Title</label>
              <select name="position" id="memberPosition">
                <option value="Professor">Professor</option>
                <option value="Associate Professor">Asso. Prof.</option>
                <option value="Assistant Professor">Asst. Prof.</option>
                <option value="Lecturer">Lecturer</option>
                <option value="Visiting Faculty">Visiting</option>
              </select>
            </div>
            <div class="form-group" style="margin:0;">
              <label for="memberSalary">Salary (₹)</label>
              <input type="number" name="salary" id="memberSalary" placeholder="60000">
            </div>
            <div class="form-group" style="margin:0;">
              <label for="memberJoinDate">Join Date</label>
              <input type="date" name="joinDate" id="memberJoinDate"
                value="<%= new Date().toISOString().split('T')[0] %>">
            </div>
            <div class="form-group" style="margin:0;">
              <label for="memberPassword">Initial Password</label>
              <input type="password" name="password" id="memberPassword" placeholder="Minimum 6 chars" minlength="6"
                required>
            </div>
          </div>

          <div style="display:flex;gap:16px;margin-top:28px;">
            <button type="submit" class="btn btn-primary" id="saveMemberBtn" style="flex:2;">✓ Create Record</button>
            <a href="/departments" class="btn btn-secondary" style="flex:1;display:flex;align-items:center;justify-content:center;">Cancel</a>
          </div>
        </form>
      </div>

    </div>
  </div>

  <script>
    async function onRoleChange() {
      const roleEl = document.getElementById('roleSelect');
      const preview = document.getElementById('previewMemberId');
      const role = roleEl.value;
      try {
        const res = await fetch(`/employees/next-id?role=${encodeURIComponent(role)}`);
        if (!res.ok) throw new Error();
        const data = await res.json();
        preview.value = data.nextId;
      } catch {
        preview.value = '';
      }
    }

    // Generate ID on load
    document.addEventListener('DOMContentLoaded', onRoleChange);
  </script>
  <script src="/app.js"></script>
</body>

</html>