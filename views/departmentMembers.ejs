<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= dept.name %> — Members — EMS</title>
  <meta name="description" content="View all members of the <%= dept.name %> department in the Employee Management System.">
  <link rel="stylesheet" href="/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* ── Member card ── */
    .member-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      transition: transform 0.22s cubic-bezier(0.4,0,0.2,1), box-shadow 0.22s ease, border-color 0.22s ease;
      display: flex;
      flex-direction: column;
    }
    .member-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
      border-color: rgba(99,102,241,0.3);
    }

    .member-card-header {
      position: relative;
      padding: 28px 20px 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      background: linear-gradient(145deg, var(--bg-secondary), var(--bg-card));
    }

    .member-avatar {
      width: 68px;
      height: 68px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.65rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 12px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.18);
      position: relative;
      flex-shrink: 0;
    }
    .member-avatar::after {
      content: '';
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      background: inherit;
      opacity: 0.2;
      z-index: -1;
    }

    .member-name {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 4px;
      line-height: 1.3;
    }
    .member-position {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    .member-card-body {
      padding: 14px 18px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      flex: 1;
    }

    .member-info-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.8rem;
      color: var(--text-secondary);
      min-width: 0;
    }
    .member-info-row .icon { font-size: 0.9rem; flex-shrink: 0; width: 18px; text-align: center; }
    .member-info-row span { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .member-att-bar {
      height: 5px;
      border-radius: 10px;
      background: var(--bg-secondary);
      overflow: hidden;
      margin: 4px 0 2px;
    }
    .member-att-bar-fill {
      height: 100%;
      border-radius: 10px;
      transition: width 0.6s ease;
    }

    .member-card-footer {
      padding: 12px 18px;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 8px;
    }
    .member-card-footer .btn {
      flex: 1;
      font-size: 0.78rem;
      padding: 7px 10px;
    }

    /* ── HOD Banner ── */
    .hod-banner {
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
      border-radius: var(--radius-lg);
      padding: 28px 32px;
      display: flex;
      align-items: center;
      gap: 24px;
      color: #fff;
      margin-bottom: 28px;
      box-shadow: 0 8px 32px rgba(99,102,241,0.35);
    }
    .hod-banner-avatar {
      width: 64px;
      height: 64px;
      background: rgba(255,255,255,0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      font-weight: 800;
      flex-shrink: 0;
    }
    .hod-banner-info { flex: 1; min-width: 0; }
    .hod-banner-info h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 2px; }
    .hod-banner-info p  { font-size: 0.82rem; opacity: 0.85; }

    /* ── Stats  row ── */
    .dept-stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 12px;
      margin-bottom: 28px;
    }
    .dept-stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 18px 14px;
      text-align: center;
      transition: box-shadow 0.2s;
    }
    .dept-stat-card:hover { box-shadow: var(--shadow-sm); }
    .dept-stat-num { font-size: 1.7rem; font-weight: 800; line-height: 1; }
    .dept-stat-lbl { font-size: 0.74rem; color: var(--text-muted); margin-top: 4px; font-weight: 500; }

    /* ── Members grid ── */
    .members-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
      gap: 18px;
    }

    /* ── Filter/search bar ── */
    .filter-bar {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 14px 18px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: flex-end;
      margin-bottom: 22px;
    }

    /* role pill select */
    .role-pills { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .role-pill {
      padding: 5px 14px;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
      border: 1.5px solid var(--border);
      background: var(--bg-secondary);
      color: var(--text-muted);
      cursor: pointer;
      text-decoration: none;
      transition: all 0.17s;
    }
    .role-pill:hover, .role-pill.active { background: var(--accent); color: #fff; border-color: var(--accent); }

    @media (max-width: 640px) {
      .members-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
      .hod-banner { flex-direction: column; text-align: center; }
    }
    @media (max-width: 400px) {
      .members-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- ═══════════ NAVBAR ═══════════ -->
<nav class="navbar">
  <a href="/departments" class="nav-brand">
    <div class="brand-icon">E</div>
    <span class="brand-name">EMS</span>
  </a>
  <div class="nav-links">
    <a href="<%= userRole === 'dean' ? '/dashboard/dean' : '/dashboard/user' %>" class="nav-link" id="nav-dash">🏠 Dashboard</a>
    <% if (userRole === 'dean') { %>
      <a href="/employees"  class="nav-link" id="nav-emp">👥 Employees</a>
    <% } %>
    <a href="/departments" class="nav-link active" id="nav-dept">🏢 Departments</a>
    <a href="/attendance"  class="nav-link" id="nav-att">📅 Attendance</a>
    <a href="/leaves"      class="nav-link" id="nav-leaves">🌴 Leaves</a>
  </div>
  <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
    <button id="themeToggle" class="theme-toggle-btn" title="Toggle dark mode">🌙</button>
    <button id="hamburger" class="hamburger-btn" aria-expanded="false"><span></span><span></span><span></span></button>
    <form action="/logout" method="POST">
      <button type="submit" class="btn btn-secondary btn-sm" id="logout-btn">Logout</button>
    </form>
  </div>
</nav>

<div id="mobileNav" class="mobile-nav">
  <a href="<%= userRole === 'dean' ? '/dashboard/dean' : '/dashboard/user' %>">🏠 Dashboard</a>
  <% if (userRole === 'dean') { %><a href="/employees">👥 Employees</a><% } %>
  <a href="/departments">🏢 Departments</a>
  <a href="/attendance">📅 Attendance</a>
  <a href="/leaves">🌴 Leaves</a>
  <div class="mobile-divider"></div>
  <form action="/logout" method="POST">
    <button type="submit" class="btn btn-secondary btn-sm" style="width:100%;">Logout</button>
  </form>
</div>

<!-- ═══════════ CONTENT ═══════════ -->
<div class="main-content">
  <div class="page-wrapper">

    <!-- Breadcrumb + Header -->
    <div class="animate-in" style="margin-bottom:24px;">
      <p style="font-size:0.8rem;color:var(--text-muted);margin-bottom:8px;">
        <a href="/departments" style="color:var(--accent);text-decoration:none;">🏢 Departments</a>
        <span style="margin:0 6px;">›</span>
        <span><%= dept.name %></span>
        <span style="margin:0 6px;">›</span>
        <span>Members</span>
      </p>
      <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;">
        <div>
          <h1 style="font-size:1.9rem;font-weight:800;"><%= dept.name %></h1>
          <p style="color:var(--text-muted);margin-top:2px;font-size:0.875rem;">Department members — <%= monthName %> attendance overview</p>
        </div>
        <div style="display:flex;gap:8px;">
          <% if (userRole === 'dean' || userRole === 'hod') { %>
            <a href="/departments" class="btn btn-secondary btn-sm no-print" id="back-btn">← Back</a>
          <% } %>
        </div>
      </div>
    </div>

    <!-- HOD Banner -->
    <% if (hod) { %>
      <div class="hod-banner animate-in delay-1">
        <div class="hod-banner-avatar"><%= hod.name.charAt(0).toUpperCase() %></div>
        <div class="hod-banner-info">
          <h3>🎓 Head of Department — <%= hod.name %></h3>
          <p><%= hod.employeeId %> · <%= hod.position || 'HOD' %> · <a href="mailto:<%= hod.email %>" style="color:#fff;opacity:0.9;"><%= hod.email %></a></p>
        </div>
        <div style="display:flex;gap:10px;flex-shrink:0;flex-wrap:wrap;">
          <a href="/employees/salary-slip/<%= hod._id %>" class="btn btn-sm no-print" style="background:rgba(255,255,255,0.2);color:#fff;border:1px solid rgba(255,255,255,0.3);" id="hodSlip">💰 Slip</a>
          <a href="/attendance/employee/<%= hod._id %>" class="btn btn-sm no-print" style="background:rgba(255,255,255,0.2);color:#fff;border:1px solid rgba(255,255,255,0.3);" id="hodAtt">📅 Att.</a>
        </div>
      </div>
    <% } else { %>
      <div class="card animate-in delay-1" style="margin-bottom:28px;padding:18px 20px;display:flex;align-items:center;gap:14px;border:2px dashed var(--border);">
        <span style="font-size:1.4rem;">⚠️</span>
        <div>
          <div style="font-weight:600;color:var(--text-primary);">No HOD Assigned</div>
          <div style="font-size:0.8rem;color:var(--text-muted);">This department currently has no Head of Department.</div>
        </div>
      </div>
    <% } %>

    <!-- Dept Stats Row -->
    <div class="dept-stat-grid animate-in delay-1">
      <div class="dept-stat-card">
        <div class="dept-stat-num" style="color:var(--accent);"><%= stats.total %></div>
        <div class="dept-stat-lbl">Total Members</div>
      </div>
      <div class="dept-stat-card">
        <div class="dept-stat-num" style="color:var(--info);"><%= stats.faculty %></div>
        <div class="dept-stat-lbl">Faculty</div>
      </div>
      <div class="dept-stat-card">
        <div class="dept-stat-num" style="color:var(--success);"><%= stats.hods %></div>
        <div class="dept-stat-lbl">HODs</div>
      </div>
      <div class="dept-stat-card">
        <div class="dept-stat-num" style="font-size:1.2rem;color:var(--warning);">₹<%= (stats.avgSalary || 0).toLocaleString('en-IN') %></div>
        <div class="dept-stat-lbl">Avg. Salary</div>
      </div>
    </div>

    <!-- Filter / Search Bar -->
    <div class="filter-bar animate-in delay-2 no-print">
      <form action="" method="GET" id="filterForm" style="display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end;flex:1;">
        <div class="form-group" style="margin:0;flex:1;min-width:170px;">
          <label for="memberSearch">Search Member</label>
          <input type="text" name="search" id="memberSearch" placeholder="Search by name…" value="<%= query.search || '' %>">
        </div>
        <div style="display:flex;align-items:flex-end;gap:8px;">
          <div>
            <label style="font-size:0.8rem;font-weight:500;color:var(--text-muted);display:block;margin-bottom:4px;">Role</label>
            <div class="role-pills">
              <a href="?search=<%= query.search||'' %>&sortBy=<%= query.sortBy||'' %>&order=<%= query.order||'' %>"
                 class="role-pill <%= !query.role ? 'active' : '' %>" id="rolePillAll">All</a>
              <a href="?role=faculty&search=<%= query.search||'' %>&sortBy=<%= query.sortBy||'' %>&order=<%= query.order||'' %>"
                 class="role-pill <%= query.role === 'faculty' ? 'active' : '' %>" id="rolePillFaculty">Faculty</a>
              <a href="?role=hod&search=<%= query.search||'' %>&sortBy=<%= query.sortBy||'' %>&order=<%= query.order||'' %>"
                 class="role-pill <%= query.role === 'hod' ? 'active' : '' %>" id="rolePillHod">HOD</a>
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-sm" id="searchBtn">Search</button>
          <a href="/departments/<%= dept._id %>/members" class="btn btn-secondary btn-sm" id="clearBtn">Clear</a>
        </div>
      </form>

      <!-- Sort selector -->
      <div style="display:flex;align-items:flex-end;gap:8px;">
        <div class="form-group" style="margin:0;min-width:130px;">
          <label for="sortBySelect">Sort By</label>
          <select id="sortBySelect" onchange="applySort()" style="font-size:0.82rem;">
            <option value="role"     <%= (query.sortBy||'role') === 'role'     ? 'selected':'' %>>Role</option>
            <option value="name"     <%= query.sortBy === 'name'     ? 'selected':'' %>>Name</option>
            <option value="salary"   <%= query.sortBy === 'salary'   ? 'selected':'' %>>Salary</option>
            <option value="joinDate" <%= query.sortBy === 'joinDate' ? 'selected':'' %>>Join Date</option>
          </select>
        </div>
        <button onclick="toggleOrder()" class="btn btn-secondary btn-sm" id="orderBtn" title="Toggle sort direction">
          <%= query.order === 'asc' ? '↑ Asc' : '↓ Desc' %>
        </button>
      </div>
    </div>

    <!-- Members Grid -->
    <% if (members.length === 0) { %>
      <div class="card animate-in" style="text-align:center;padding:60px 20px;">
        <div style="font-size:3rem;margin-bottom:12px;">🔍</div>
        <h3 style="margin-bottom:6px;">No members found</h3>
        <p style="color:var(--text-muted);">Try adjusting your search or filters.</p>
        <a href="/departments/<%= dept._id %>/members" class="btn btn-primary" style="margin-top:16px;display:inline-block;" id="clearSearchBtn">Clear Search</a>
      </div>
    <% } else { %>
      <div class="members-grid">
        <% const avatarColors = [
          'linear-gradient(135deg,#6366f1,#4338ca)',
          'linear-gradient(135deg,#10b981,#059669)',
          'linear-gradient(135deg,#f59e0b,#d97706)',
          'linear-gradient(135deg,#ef4444,#dc2626)',
          'linear-gradient(135deg,#06b6d4,#0891b2)',
          'linear-gradient(135deg,#8b5cf6,#7c3aed)',
          'linear-gradient(135deg,#ec4899,#db2777)',
          'linear-gradient(135deg,#14b8a6,#0d9488)',
        ]; %>

        <% members.forEach((member, i) => { %>
          <% const color = avatarColors[i % avatarColors.length]; %>
          <% const attPct = member.att.pct; %>
          <% const attColor = attPct >= 80 ? '#10b981' : attPct >= 60 ? '#f59e0b' : '#ef4444'; %>

          <div class="member-card animate-in delay-<%= (i % 4) + 1 %>">

            <!-- Card Header -->
            <div class="member-card-header">
              <!-- Role badge top-right -->
              <div style="position:absolute;top:12px;right:12px;">
                <% if (member.role === 'dean') { %>
                  <span class="badge badge-purple" style="font-size:0.68rem;">🎖 DEAN</span>
                <% } else if (member.role === 'hod') { %>
                  <span class="badge badge-green"  style="font-size:0.68rem;">🎓 HOD</span>
                <% } else { %>
                  <span class="badge badge-blue"   style="font-size:0.68rem;">👨‍🏫 FACULTY</span>
                <% } %>
              </div>

              <div class="member-avatar" style="background:<%= color %>;">
                <%= member.name.charAt(0).toUpperCase() %>
              </div>
              <div class="member-name"><%= member.name %></div>
              <div class="member-position"><%= member.position || (member.role === 'hod' ? 'Head of Department' : 'Faculty Member') %></div>
              <code style="font-size:0.72rem;color:var(--text-muted);background:var(--bg-secondary);padding:2px 8px;border-radius:10px;"><%= member.employeeId %></code>
            </div>

            <!-- Card Body -->
            <div class="member-card-body">
              <div class="member-info-row">
                <span class="icon">📧</span>
                <a href="mailto:<%= member.email %>" style="color:var(--accent);text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= member.email %>"><%= member.email %></a>
              </div>
              <% if (member.phone) { %>
                <div class="member-info-row">
                  <span class="icon">📞</span>
                  <span><%= member.phone %></span>
                </div>
              <% } %>
              <div class="member-info-row">
                <span class="icon">💰</span>
                <span>₹<%= member.salary ? Number(member.salary).toLocaleString('en-IN') : 'N/A' %> / month</span>
              </div>
              <div class="member-info-row">
                <span class="icon">📅</span>
                <span>Joined <%= new Date(member.joinDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></span>
              </div>

              <!-- This-month attendance bar -->
              <div style="margin-top:6px;">
                <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
                  <span style="font-size:0.75rem;color:var(--text-muted);font-weight:500;"><%= monthName %> Attendance</span>
                  <span style="font-size:0.75rem;font-weight:700;color:<%= attColor %>;"><%= attPct %>%</span>
                </div>
                <div class="member-att-bar">
                  <div class="member-att-bar-fill" style="width:<%= attPct %>%;background:<%= attColor %>;"></div>
                </div>
                <div style="display:flex;gap:10px;margin-top:5px;">
                  <span style="font-size:0.7rem;color:var(--success);font-weight:600;">✓ <%= member.att.present %>P</span>
                  <span style="font-size:0.7rem;color:var(--warning);font-weight:600;">⏰ <%= member.att.late %>L</span>
                  <span style="font-size:0.7rem;color:var(--danger);font-weight:600;">✗ <%= member.att.absent %>A</span>
                  <% if (member.att.total === 0) { %>
                    <span style="font-size:0.7rem;color:var(--text-muted);">No records yet</span>
                  <% } %>
                </div>
              </div>
            </div>

            <!-- Card Footer Actions -->
            <div class="member-card-footer no-print">
              <a href="/attendance/employee/<%= member._id %>" class="btn btn-secondary btn-sm" id="attBtn_<%= member._id %>">📅 Attendance</a>
              <a href="/employees/salary-slip/<%= member._id %>" class="btn btn-secondary btn-sm" id="slipBtn_<%= member._id %>">💰 Salary Slip</a>
            </div>

          </div>
        <% }) %>
      </div>

      <p class="no-print" style="text-align:center;margin-top:24px;font-size:0.8rem;color:var(--text-muted);">
        Showing <%= members.length %> member<%= members.length !== 1 ? 's' : '' %>
        <% if (query.search || query.role) { %> matching your filters<% } %>
      </p>
    <% } %>

  </div>
</div>

<script>
  function applySort() {
    const sortBy = document.getElementById('sortBySelect').value;
    const params = new URLSearchParams(window.location.search);
    params.set('sortBy', sortBy);
    window.location.search = params.toString();
  }
  function toggleOrder() {
    const params = new URLSearchParams(window.location.search);
    params.set('order', params.get('order') === 'asc' ? 'desc' : 'asc');
    window.location.search = params.toString();
  }
</script>
<script src="/app.js"></script>
</body>
</html>
